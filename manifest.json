{
  "manifest_version": 3,
  "name": "ThreadView",
  "version": "1.0.0",
  "description": "Open Gmail threads in a clean reading view by tapping into Gmail's print template.",
  "minimum_chrome_version": "120",

  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*"
  ],

  "background": {
    "service_worker": "src/background/sw.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content/inject.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "src/viewer/viewer.html",
        "src/viewer/viewer.js",
        "src/viewer/viewer.css",
        "src/content/inject.css",
        "src/lib/*"
      ],
      "matches": ["https://mail.google.com/*"]
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
